# Copy to .env and adjust. Used by Docker Compose and local tools.

# PostgreSQL (Compose service `postgres`)
POSTGRES_USER=canine
POSTGRES_PASSWORD=canine
POSTGRES_DB=canine

# Backend — async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://canine:canine@postgres:5432/canine

# JWT signing (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret

# Mistral API (free tier key from https://console.mistral.ai/)
MISTRAL_API_KEY=

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3000

# Frontend — public API base URL (browser; also default for host `npm run dev`)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend — server-side fetch base (Docker Compose: reach API by service name)
# Omit on the host; set automatically in compose to http://backend:8000
# API_URL=http://backend:8000

# Frontend dev container: UID for `npm run dev` after entrypoint chown (default 1001 in compose)
# CONTAINER_RUN_UID=1001

# Frontend-only preview (optional): set to 1 when running without the API (see make up-frontend-standalone)
# NEXT_PUBLIC_STANDALONE=1
